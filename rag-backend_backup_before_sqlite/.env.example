# OpenAI 서버 전용 키: 실제 값은 rag-backend/.env에만 입력
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_CHAT_MODEL=gpt-4o-mini

# JWT 인증
JWT_SECRET_KEY=CHANGE_TO_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# SQLite: 비워두면 rag-backend/data/pine_wilt.db 사용
DATABASE_URL=sqlite:///./data/pine_wilt.db
# 또는 절대경로 사용 가능
# SQLITE_PATH=/opt/pine-wilt/rag-backend/data/pine_wilt.db

# MySQL → SQLite 1회 이전 스크립트에서만 사용
MYSQL_SOURCE_HOST=
MYSQL_SOURCE_PORT=3306
MYSQL_SOURCE_DB=
MYSQL_SOURCE_USER=
MYSQL_SOURCE_PASSWORD=

# 원본 백서 PDF와 ChromaDB 경로
DOCS_DIR=./data/docs
VECTOR_BACKEND=chroma
CHROMA_DIR=./data/chroma

# 프론트 허용 주소(쉼표 구분)
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://101.79.24.212

# Supabase 벡터 저장소를 쓸 때만 설정
SUPABASE_URL=
SUPABASE_KEY=
