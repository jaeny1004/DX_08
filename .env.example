# Frontend -> FastAPI base URL
# Local development example:
VITE_API_BASE_URL=http://127.0.0.1:8788

# Existing variable name supported for compatibility.
# VITE_RAG_API_BASE=http://127.0.0.1:8788

# Authentication preview mode (true only for UI demonstration)
VITE_AUTH_PREVIEW_MODE=false

# VWorld map key
VITE_VWORLD_KEY=YOUR_VWORLD_KEY

# Roboflow is called only through a server-side endpoint.
# Never put a private Roboflow API key in a VITE_ variable.
