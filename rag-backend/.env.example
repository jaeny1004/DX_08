# OpenAI 서버 전용 키: 실제 값은 rag-backend/.env에만 입력
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_CHAT_MODEL=gpt-4o-mini

# 원본 백서 PDF와 ChromaDB 경로
DOCS_DIR=./data/docs
VECTOR_BACKEND=chroma
CHROMA_DIR=./data/chroma

# 프론트 개발 서버 허용 주소(쉼표 구분)
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Supabase 벡터 저장소를 쓸 때만 설정
SUPABASE_URL=
SUPABASE_KEY=
